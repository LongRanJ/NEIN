{
  "sources": [
    {
      "id": "sina",
      "name": "新浪新闻",
      "url_template": "https://search.sina.com.cn/?q={keyword}&range=all&time=0",
      "type": "list",
      "selectors": {
        "container": [".result-item", ".box-result"],
        "title": ["h2 a", "h3 a", ".title a"],
        "summary": [".summary", ".content", "p"],
        "link": ["h2 a[href]", "h3 a[href]"]
      },
      "enabled": true
    },
    {
      "id": "qq",
      "name": "腾讯新闻",
      "url_template": "https://news.qq.com/search?q={keyword}",
      "type": "list",
      "selectors": {
        "container": [".list_item", ".search-item", ".item-wrap"],
        "title": [".title a", "h3 a", ".item-title a"],
        "summary": [".desc", ".summary", ".item-desc"],
        "link": [".title a[href]", "h3 a[href]"]
      },
      "enabled": true
    },
    {
      "id": "sohu",
      "name": "搜狐新闻",
      "url_template": "https://search.sohu.com/?keyword={keyword}",
      "type": "list",
      "selectors": {
        "container": [".result-item", ".news-item", ".search-result-item"],
        "title": [".title a", "h3 a", "h2 a"],
        "summary": [".summary", ".desc", "p"],
        "link": [".title a[href]", "h3 a[href]"]
      },
      "enabled": true
    },
    {
      "id": "163",
      "name": "网易新闻",
