        "summary": [".summary", ".desc", "p"],
        "link": [".title a[href]", "h3 a[href]"]
      },
      "enabled": true
    },
    {
      "id": "baidu",
      "name": "百度新闻",
      "url_template": "https://news.baidu.com/ns?word={keyword}",
      "type": "list",
      "selectors": {
        "container": [".result", ".news-item", "li"],
        "title": [".news-title a", "h3 a", ".c-title a"],
        "summary": [".c-summary", ".c-abstract", ".summary"],
        "link": [".news-title a[href]", "h3 a[href]"]
      },
      "enabled": true
    },
    {
      "id": "toutiao",
      "name": "今日头条",
      "url_template": "https://so.toutiao.com/search?keyword={keyword}&type=news",
      "type": "list",
      "selectors": {
        "container": [".result-content", ".search-result-item", ".cs-view-block"],
        "title": [".text-ellipsis a", "h3 a", ".title a"],
        "summary": [".desc", ".summary", ".content"],
        "link": [".text-ellipsis a[href]", "h3 a[href]"]
