    {
      "id": "chinanews",
      "name": "中国新闻网",
      "url_template": "https://www.chinanews.com/search?keyword={keyword}",
      "type": "list",
      "selectors": {
        "container": [".news-item", ".search-result-item", ".result-item"],
        "title": [".title a", "h3 a", "h2 a"],
        "summary": [".summary", ".desc", "p"],
