      },
      "enabled": true
    },
    {
      "id": "cankaoxiaoxi",
      "name": "参考消息",
      "url_template": "https://search.cankaoxiaoxi.com/?q={keyword}",
      "type": "special",
      "selectors": {
        "container": [".result-item", ".news-item", ".search-item"],
